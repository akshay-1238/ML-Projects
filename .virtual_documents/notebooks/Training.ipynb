





import pandas as pd
from sklearn.model_selection import train_test_split


df = pd.read_csv('data/Data.csv')
df.head()


x = df.drop('charges', axis = 1)
y = df['charges']


import numpy as np
y_log = np.log(y) #Creating log to avoid negetive charges


x_train, x_test, y_train, y_test = train_test_split(x, y_log, test_size = 0.20, random_state = 42)








from sklearn.linear_model import LinearRegression


model = LinearRegression()
model.fit(x_train, y_train)





y_pred_log = model.predict(x_test)
y_pred = np.exp(y_pred_log)


print(f"Predicted values are: \n{ y_pred[:10]} .........")


y_actual_test = np.exp(y_test)
y_actual_test








from sklearn.metrics import r2_score

r2 = r2_score(y_actual_test, y_pred)

n = x_test.shape[0]
p = x_test.shape[1]

adjusted_r2 = 1 - ((1 - r2) * (n - 1) / (n - p - 1))


print("Model accuracy with r2 is: \n", r2)


print("Model accuracy with adjusted r2 is: ", adjusted_r2)



