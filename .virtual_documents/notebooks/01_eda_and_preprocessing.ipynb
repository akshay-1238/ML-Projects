from sklearn.preprocessing import StandardScaler
cols = ['age', 'bmi', 'children']
scaler = StandardScaler()

df_cleaned[cols] = scaler.fit_transform(df_cleaned[cols])
df_cleaned





from scipy.stats import pearsonr
features = ['age', 'bmi', 'children', 'charges', 'is_female', 'is_smoker',
       'region_northeast', 'region_northwest', 'region_southeast',
       'region_southwest', 'bmi_category_Underweight', 'bmi_category_Normal',
       'bmi_category_Overweight', 'bmi_category_Obese']

correlations = {
    feature : pearsonr(df_cleaned[feature], df_cleaned['charges'])[0] for feature in features
}

correlations_df = pd.DataFrame(list(correlations.items()), columns = ['Feature', 'Pearson Correlation'])
correlations_df.sort_values(by = 'Pearson Correlation', ascending = False)





categorical_features = ['is_female', 'is_smoker',
       'region_northeast', 'region_northwest', 'region_southeast',
       'region_southwest', 'bmi_category_Underweight', 'bmi_category_Normal',
       'bmi_category_Overweight', 'bmi_category_Obese']


from scipy.stats import chi2_contingency

alpha = 0.05
  
df_cleaned['charges_bin'] = pd.qcut(df_cleaned['charges'], q = 4, labels = False)
chi2_result = {}

for col in categorical_features:
    contigency = pd.crosstab(df_cleaned[col], df_cleaned['charges_bin'])
    chi2_state, p_val, _, _ = chi2_contingency(contigency)
    decision = 'Reject Null (Keep Feature)' if p_val < alpha else 'Accept Null(Drop Feature)'
    chi2_result[col] = {
        'chi2_statistic' : chi2_state,
        'p_value' : p_val,
        'Decision' : decision
    }

chi2_df = pd.DataFrame(chi2_result).T
chi2_df = chi2_df.sort_values(by = 'p_value')
chi2_df





final_df = df_cleaned[['age', 'is_female', 'bmi', 'children', 'is_smoker', 'charges', 'region_southwest', 'bmi_category_Obese']]


final_df


final_df.to_csv('../data/hot_label_encoded.csv', index=False)



